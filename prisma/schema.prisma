// GymPlan – Datenmodell
// SQLite lokal; für Cloud später nur provider/url auf postgresql tauschen.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Accounts & Login -----------------------------------------------------

model Account {
  id                 String              @id @default(cuid())
  username           String              @unique
  passwordHash       String // scrypt: salt:hash (hex)
  role               String // TRAINER | CLIENT
  displayName        String // Anzeigename; bei Kunden = clientName in Sessions
  funnyOrder         String? // JSON-Array gemischter Spruch-Indizes (einmal pro Account erzeugt)
  funnyCursor        Int                 @default(0)
  createdAt          DateTime            @default(now())
  authSessions       AuthSession[]
  plans              Plan[] // zugewiesene Pläne (nur Kunden)
  programs           Program[] // zugewiesene Programme (nur Kunden)
  weeklySchedules    WeeklySchedule[]
  trainingPreference TrainingPreference?
  standardWeek       StandardWeek?
}

// Persistenter Trainingsrhythmus des Kunden (jederzeit änderbar).
model TrainingPreference {
  id        String   @id @default(cuid())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String   @unique
  weekdays  String   @default("[]") // JSON-Array Int 0–6, Mo=0: Tage mit Zeit
  frequency Int      @default(3) // gewünschte Einheiten pro Woche
  updatedAt DateTime @updatedAt
}

// Vom Trainer zugeteilte Standardwoche: gilt jede Woche, bis sie geändert
// wird. updatedAt = Zeitpunkt der letzten Zuteilung (für den Abgleich mit
// TrainingPreference.updatedAt → "Verfügbarkeit geändert"-Hinweis).
model StandardWeek {
  id        String              @id @default(cuid())
  account   Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String              @unique
  updatedAt DateTime            @updatedAt
  entries   StandardWeekEntry[]
}

model StandardWeekEntry {
  id       String       @id @default(cuid())
  week     StandardWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  weekId   String
  plan     Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId   String
  weekday  Int // 0=Mo … 6=So
  position Int          @default(0) // Modell erlaubt mehrere Einheiten/Tag; UI nutzt nur 0

  @@unique([weekId, weekday, position])
}

// --- Programme & Wochenplanung ---------------------------------------------

// Mehrtägiger Trainingszyklus (z.B. 3er-Split): geordnete Folge von Plänen.
model Program {
  id           String       @id @default(cuid())
  name         String
  ownerName    String
  assignedTo   Account?     @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId String?
  createdAt    DateTime     @default(now())
  days         ProgramDay[]
}

model ProgramDay {
  id        String  @id @default(cuid())
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  plan      Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId    String
  order     Int     @default(0)

  @@unique([programId, planId])
}

// Wochen-Ausnahme: existiert eine Zeile für accountId+weekStart, ersetzen
// ihre Entries die Standardwoche komplett (0 Entries = trainingsfreie Woche).
model WeeklySchedule {
  id        String          @id @default(cuid())
  account   Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String
  weekStart DateTime // Montag der Woche, als UTC-Mitternacht des lokalen Datums
  createdAt DateTime        @default(now())
  entries   ScheduleEntry[]

  @@unique([accountId, weekStart])
}

model ScheduleEntry {
  id         String         @id @default(cuid())
  schedule   WeeklySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId String
  plan       Plan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId     String
  date       DateTime // Tages-Datum als UTC-Mitternacht des lokalen Datums
  position   Int            @default(0) // Reihenfolge bei zusammengelegten Einheiten

  @@index([scheduleId, date])
}

model AuthSession {
  token     String   @id
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// --- Muskeln & Übungen --------------------------------------------------

model Muscle {
  id        String           @id @default(cuid())
  name      String           @unique // Anzeigename, z.B. "Brust"
  group     String // grobe Gruppe, z.B. "Oberkörper"
  bodyPart  String // "FRONT" | "BACK" – auf welcher Körperseite gezeichnet
  svgKey    String           @unique // ID des Pfads in der BodyMap-SVG
  exercises ExerciseMuscle[]
}

model Exercise {
  id        String           @id @default(cuid())
  name      String           @unique
  equipment String // KETTLEBELL | DUMBBELL | BARBELL | BODYWEIGHT | MACHINE | CABLE | OTHER
  category  String? // z.B. "Push", "Pull", "Legs"
  notes     String?
  imageUrl  String? // Beispielbild/Anleitung der Übung
  muscles   ExerciseMuscle[]
  planItems PlanExercise[]
  createdAt DateTime         @default(now())
}

// Verknüpfung Übung <-> Muskel mit Anteil in Prozent (Summe je Übung ~100)
model ExerciseMuscle {
  id         String   @id @default(cuid())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId String
  muscle     Muscle   @relation(fields: [muscleId], references: [id], onDelete: Cascade)
  muscleId   String
  percentage Int

  @@unique([exerciseId, muscleId])
}

// --- Pläne --------------------------------------------------------------

model Plan {
  id                  String              @id @default(cuid())
  name                String
  ownerName           String // Trainer / Ersteller
  shareToken          String              @unique @default(cuid())
  assignedTo          Account?            @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId        String?
  createdAt           DateTime            @default(now())
  exercises           PlanExercise[]
  sessions            WorkoutSession[]
  programDays         ProgramDay[]
  scheduleEntries     ScheduleEntry[]
  standardWeekEntries StandardWeekEntry[]
}

model PlanExercise {
  id           String   @id @default(cuid())
  plan         Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId       String
  exercise     Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  exerciseId   String
  order        Int      @default(0)
  sets         Int      @default(3)
  targetReps   Int?
  targetWeight Float?
  setLogs      SetLog[]
}

// --- Trainings-Sessions (Kunde) ----------------------------------------

model Client {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model WorkoutSession {
  id         String    @id @default(cuid())
  plan       Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId     String
  clientName String
  motivation Int? // 1–20, vor dem Training
  exertion   Int? // 1–20, nach dem Training
  status     String    @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | CANCELLED
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  setLogs    SetLog[]
}

model SetLog {
  id             String         @id @default(cuid())
  session        WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId      String
  planExercise   PlanExercise   @relation(fields: [planExerciseId], references: [id], onDelete: Cascade)
  planExerciseId String
  setNumber      Int
  weight         Float?
  reps           Int?
  durationMin    Int? // Cardio: Dauer in Minuten
  intensity      Int? // Cardio: Intensität 1–5
}
